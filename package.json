{
  "name": "mudancas-logistica",
  "version": "1.0.0",
  "private": true,
  "description": "Sistema de Gestão de Mudanças - SaaS Multi-tenant",
  "scripts": {
    "dev": "concurrently \"npm:dev:*\"",
    "dev:backend": "npm run dev --workspace=@mudancas/backend",
    "dev:admin": "npm run dev --workspace=@mudancas/admin",
    "dev:pwa": "npm run dev --workspace=@mudancas/pwa",
    "dev:site": "npm run dev --workspace=@mudancas/site",
    "dev:superadmin": "npm run dev --workspace=@mudancas/superadmin",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces",
    "db:migrate": "npm run db:migrate --workspace=@mudancas/backend",
    "db:seed": "npm run db:seed --workspace=@mudancas/backend"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
